<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/chat_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:gravity="bottom|center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="12dp">

            <ImageButton
                android:id="@+id/nav_model"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_chat_header_button"
                android:contentDescription="模型配置"
                android:padding="11dp"
                android:src="@drawable/ic_menu"
                android:tint="#111111" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="62dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="25dp"
                    android:gravity="center"
                    android:minWidth="92dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="豆芽 ›"
                    android:textColor="#111111"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/model_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:ellipsize="end"
                    android:maxWidth="170dp"
                    android:minWidth="72dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:singleLine="true"
                    android:text="内容由 AI 生成"
                    android:textColor="#A0A4AA"
                    android:textSize="13sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/nav_call"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_chat_header_button"
                android:contentDescription="语音通话"
                android:padding="10dp"
                android:src="@drawable/ic_phone"
                android:tint="#111111" />

        </LinearLayout>

        <ScrollView
            android:id="@+id/chat_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:paddingTop="8dp"
            android:paddingBottom="18dp">

            <LinearLayout
                android:id="@+id/chat_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/suggestion_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_suggestion_chip"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="快速"
                    android:textColor="#111111"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/suggestion_create"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_suggestion_chip"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="AI 创作"
                    android:textColor="#111111"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/suggestion_minutes"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_suggestion_chip"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="拍题答疑"
                    android:textColor="#111111"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/suggestion_qa"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_suggestion_chip"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="深入研究"
                    android:textColor="#111111"
                    android:textSize="15sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_input_dock"
            android:elevation="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="8dp">

            <ImageButton
                android:id="@+id/chat_camera"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_chat_input_icon"
                android:contentDescription="拍照"
                android:padding="9dp"
                android:src="@drawable/ic_camera"
                android:tint="#111111" />

            <EditText
                android:id="@+id/chat_input"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="发消息或按住说话..."
                android:paddingStart="8dp"
                android:paddingEnd="6dp"
                android:singleLine="true"
                android:textColor="#111111"
                android:textColorHint="#A8AAB0"
                android:textSize="16sp" />

            <ImageButton
                android:id="@+id/chat_voice"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_chat_input_icon"
                android:contentDescription="语音输入"
                android:padding="8dp"
                android:src="@drawable/ic_voice_circle"
                android:tint="#111111" />

            <ImageButton
                android:id="@+id/chat_send"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_chat_input_icon"
                android:contentDescription="更多"
                android:padding="8dp"
                android:src="@drawable/ic_plus"
                android:tint="#111111" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/call_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_voice_scene"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingBottom="24dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="108dp"
            android:gravity="bottom|center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/interrupt_button"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_call_top_button"
                android:contentDescription="返回文字对话"
                android:gravity="center"
                android:text="×"
                android:textColor="#FF2D2D"
                android:textSize="30sp"
                android:visibility="invisible" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_douya_header"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:id="@+id/douya_title"
                    android:background="@drawable/bg_douya_name_badge"
                    android:gravity="center"
                    android:minWidth="92dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="语音通话"
                    android:textColor="#0F766E"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/call_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:text="实时语音对话 · 00:00"
                    android:textColor="#64748B"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/subtitle_button"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_call_top_button"
                android:contentDescription="返回文字对话"
                android:gravity="center"
                android:text="字"
                android:textColor="#18191C"
                android:textSize="20sp"
                android:textStyle="bold"
                android:visibility="invisible" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.18" />

        <FrameLayout
            android:layout_width="310dp"
            android:layout_height="310dp"
            android:layout_gravity="center">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_voice_circle"
                android:padding="10dp">

                <com.example.aivoice.AvatarView
                    android:id="@+id/avatar_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>
        </FrameLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.18" />

        <TextView
            android:id="@+id/call_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:minHeight="36dp"
            android:text="轻点麦克风开始说话"
            android:textColor="#0F172A"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_douya_subtitle"
            android:gravity="center"
            android:ellipsize="end"
            android:lineSpacingExtra="4dp"
            android:maxLines="2"
            android:minHeight="86dp"
            android:text="字幕会显示语音识别和模型回复"
            android:textColor="#334155"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/transcript"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@drawable/bg_transcript"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Transcript 会保留最近一次通话内容。"
            android:textColor="#64748B"
            android:textSize="15sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:gravity="center"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageButton
                    android:id="@+id/mic_button"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_doubao_call_button"
                    android:contentDescription="麦克风"
                    android:padding="20dp"
                    android:src="@drawable/ic_mic"
                    android:tint="#18191C" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageButton
                    android:id="@+id/call_send"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_doubao_call_button"
                    android:contentDescription="发送"
                    android:padding="20dp"
                    android:src="@drawable/ic_call_card_upload" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageButton
                    android:id="@+id/call_video"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_doubao_call_button"
                    android:contentDescription="视频"
                    android:padding="20dp"
                    android:src="@drawable/ic_video"
                    android:tint="#18191C" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageButton
                    android:id="@+id/call_close"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_doubao_call_button"
                    android:contentDescription="结束通话"
                    android:padding="20dp"
                    android:src="@drawable/ic_hangup_x"
                    android:tint="#FF2D2D" />
            </FrameLayout>
        </LinearLayout>

        <EditText
            android:id="@+id/call_input"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:alpha="0"
            android:singleLine="true" />

    </LinearLayout>

    <ScrollView
        android:id="@+id/model_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_app"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/model_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="64dp">

            <ImageButton
                android:id="@+id/model_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_tool_button"
                android:contentDescription="返回"
                android:padding="12dp"
                android:src="@drawable/ic_menu"
                android:tint="#0F172A" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="模型配置"
                android:textColor="#0F172A"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="18dp"
                android:text="配置 OpenAI-compatible 接口后，对话和通话会使用同一个真实模型。"
                android:textColor="#64748B"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/model_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingTop="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="14dp">

                <EditText
                    android:id="@+id/model_name_input"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_input"
                    android:hint="名称，例如：我的模型"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8" />

                <EditText
                    android:id="@+id/base_url_input"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="Base URL，例如：https://api.openai.com/v1"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8" />

                <EditText
                    android:id="@+id/api_key_input"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="API Key"
                    android:inputType="textPassword"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8" />

                <EditText
                    android:id="@+id/model_id_input"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="Model ID，例如：gpt-4o-mini"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8" />

                <EditText
                    android:id="@+id/speech_model_id_input"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="实时语音模型 ID，例如：gpt-4o-mini-transcribe"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8" />

                <EditText
                    android:id="@+id/volc_app_id_input"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="火山语音 AppID"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8" />

                <EditText
                    android:id="@+id/volc_app_key_input"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="火山语音 AppKey"
                    android:inputType="textPassword"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8" />

                <EditText
                    android:id="@+id/volc_token_input"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="火山语音 Token"
                    android:inputType="textPassword"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8" />

                <EditText
                    android:id="@+id/volc_resource_id_input"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="火山语音 Resource ID，默认 volc.speech.dialog"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8" />

                <EditText
                    android:id="@+id/volc_cluster_input"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="火山语音 Cluster，默认 volcengine_streaming_common"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8" />

                <EditText
                    android:id="@+id/volc_bot_name_input"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="火山智能体名称，例如：豆包"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8" />

                <EditText
                    android:id="@+id/volc_payload_input"
                    android:layout_width="match_parent"
                    android:layout_height="96dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:gravity="top|start"
                    android:hint="火山 StartSession Payload JSON，可留空"
                    android:inputType="textMultiLine"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8" />

                <EditText
                    android:id="@+id/timeout_input"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="超时时间 ms，默认 15000"
                    android:inputType="number"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8" />

                <CheckBox
                    android:id="@+id/model_enabled_check"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:checked="true"
                    android:text="启用这个模型"
                    android:textColor="#334155"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/save_model_button"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_primary_button"
                    android:text="保存并设为默认"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/voice_hold_overlay"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_voice_hold_overlay"
        android:clickable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="44dp"
        android:visibility="gone">

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/voice_hold_hint"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="松手发送，上移取消"
            android:textColor="#EAF4FF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/voice_hold_wave"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="44dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:letterSpacing="0.08"
            android:text="||||||||||||||||||||||||||||||||||||||||||||||||"
            android:textColor="#EAF4FF"
            android:textSize="24sp" />
    </LinearLayout>

</FrameLayout>
